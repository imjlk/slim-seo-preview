#. Plugin Name of the plugin
#: slim-seo-preview.php src/index.js:1262
msgid "Slim SEO Preview"
msgstr "Slim SEO Preview"

#. Description of the plugin
#: slim-seo-preview.php
msgid ""
"Adds Gutenberg SERP, Open Graph, and applied schema previews for Slim SEO "
"with a quick noindex toggle."
msgstr ""
"Slim SEO용 구텐베르크 SERP, Open Graph, 적용된 스키마 미리보기를 제공하고 빠"
"른 noindex 토글을 추가합니다."

#. Author of the plugin
#: slim-seo-preview.php
msgid "imjlk"
msgstr "imjlk"

#: src/Editor.php:28
msgid "Slim SEO Preview requires Slim SEO to be installed and active."
msgstr ""
"Slim SEO Preview를 사용하려면 Slim SEO가 설치 및 활성화되어 있어야 합니다."

#: src/Editor.php:86
msgid "Slim SEO Preview requires Slim SEO to stay active."
msgstr ""
"Slim SEO Preview를 사용하려면 Slim SEO가 계속 활성화되어 있어야 합니다."

#: src/Editor.php:87 src/index.js:1344
msgid "You do not have permission to update SEO settings for this item."
msgstr "이 항목의 SEO 설정을 업데이트할 권한이 없습니다."

#: src/Editor.php:88
msgid ""
"Slim SEO Preview could not load Slim SEO data. The existing Slim SEO meta "
"box remains available below."
msgstr ""
"Slim SEO Preview가 Slim SEO 데이터를 불러오지 못했습니다. 기존 Slim SEO 메타 "
"박스는 아래에서 계속 사용할 수 있습니다."

#: src/Editor.php:89
msgid ""
"This post type is globally set to noindex in Slim SEO, so the per-post "
"toggle is locked here."
msgstr ""
"이 글 타입은 Slim SEO에서 전역적으로 noindex로 설정되어 있어, 개별 글 토글이 "
"여기서는 잠겨 있습니다."

#: src/Editor.php:90 src/index.js:1360
msgid "Jump to Slim SEO meta box"
msgstr "Slim SEO 메타 박스로 이동"

#: src/Editor.php:91 src/index.js:1361
msgid "The Slim SEO meta box could not be found on this screen."
msgstr "이 화면에서 Slim SEO 메타 박스를 찾을 수 없습니다."

#: src/Editor.php:152
msgid "A valid post ID is required."
msgstr "유효한 글 ID가 필요합니다."

#: src/Editor.php:160 src/Editor.php:233
msgid "The requested post could not be found."
msgstr "요청한 글을 찾을 수 없습니다."

#: src/Editor.php:168
msgid "You are not allowed to preview or update SEO data for this post."
msgstr "이 글의 SEO 데이터를 미리 보거나 업데이트할 권한이 없습니다."

#: src/Editor.php:181
msgid "Slim SEO must be active to read noindex state."
msgstr "noindex 상태를 읽으려면 Slim SEO가 활성화되어 있어야 합니다."

#: src/Editor.php:194
msgid "Slim SEO must be active to update noindex state."
msgstr "noindex 상태를 업데이트하려면 Slim SEO가 활성화되어 있어야 합니다."

#: src/Editor.php:224
msgid "Slim SEO must be active to read schema preview data."
msgstr "스키마 미리보기 데이터를 읽으려면 Slim SEO가 활성화되어 있어야 합니다."

#: src/Editor.php:241
msgid ""
"Applied schema preview is only available for publicly viewable entries "
"because it reads the saved frontend HTML."
msgstr ""
"적용된 스키마 미리보기는 저장된 프런트엔드 HTML을 읽기 때문에 공개적으로 볼 "
"수 있는 항목에서만 사용할 수 있습니다."

#: src/Editor.php:253
msgid "Slim SEO Preview could not determine a frontend URL for this entry."
msgstr "Slim SEO Preview가 이 항목의 프런트엔드 URL을 확인하지 못했습니다."

#. translators: %d: HTTP status code.
#: src/Editor.php:295
msgid ""
"Slim SEO Preview could not load the rendered page. HTTP %d was returned."
msgstr ""
"Slim SEO Preview가 렌더링된 페이지를 불러오지 못했습니다. HTTP %d 응답이 반환"
"되었습니다."

#: src/Editor.php:303
msgid "Slim SEO Preview could not load the rendered page."
msgstr "Slim SEO Preview가 렌더링된 페이지를 불러오지 못했습니다."

#: src/Editor.php:374
msgid "The post ID for the current editor entry."
msgstr "현재 편집기 항목의 글 ID입니다."

